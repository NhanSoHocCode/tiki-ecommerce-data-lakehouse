iceberg.jdbc-catalog.default-warehouse-dir=s3://lakehouse/iceberg/

# Iceberg formats
iceberg.file-format=PARQUET

# MinIO Connection
fs.s3.enabled=true
s3.endpoint=http://minio:9000
